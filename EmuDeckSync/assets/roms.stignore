// Cemu and Xenia store saves below their ROM trees. These paths are shared as
// separate, versioned save folders after EmuDeck is installed on both hosts.
/wiiu/mlc01/usr/save
/xbox360/content

// EmuDeck creates this as an absolute, host-specific symlink. Each host keeps
// its own working link; it must not enter Syncthing's cross-device index.
/psvita/InstalledGames
