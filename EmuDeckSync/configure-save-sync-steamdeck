#!/usr/bin/env bash
set -Eeuo pipefail

if [[ "$(id -un)" != deck ]]; then
    echo "Run this script as deck, without sudo." >&2
    exit 1
fi
if (( $# != 1 )); then
    echo "Usage: $0 UBUNTU_DEVICE_ID" >&2
    exit 1
fi

remote_id=$1
syncthing="$HOME/.local/bin/syncthing"
root="$HOME/Emulation"
local_id="$($syncthing device-id)"

systemctl --user is-active --quiet syncthing.service
if ! "$syncthing" cli config devices list | grep -Fxq "$remote_id"; then
    echo "Ubuntu is not configured as a Syncthing device." >&2
    exit 1
fi

folders=(
    "save-cemu|Cemu saves|$root/roms/wiiu/mlc01/usr/save"
    "save-vita3k|Vita3K saves|$root/storage/Vita3K/ux0/user/00/savedata"
    "save-azahar|Azahar saves|$root/storage/azahar/sdmc"
    "state-azahar|Azahar save states|$HOME/.local/share/azahar-emu/states"
    "save-citron|Citron saves|$root/storage/citron/nand/user/save"
    "profile-citron|Citron profiles|$root/storage/citron/nand/system/save/8000000000000010/su/avators"
    "save-dolphin-gc|Dolphin GameCube saves|$HOME/.var/app/org.DolphinEmu.dolphin-emu/data/dolphin-emu/GC"
    "save-dolphin-wii|Dolphin Wii saves|$HOME/.var/app/org.DolphinEmu.dolphin-emu/data/dolphin-emu/Wii"
    "state-dolphin|Dolphin save states|$HOME/.var/app/org.DolphinEmu.dolphin-emu/data/dolphin-emu/StateSaves"
    "save-duckstation|DuckStation saves and states|$root/saves/duckstation"
    "save-melonds|melonDS saves and states|$root/saves/melonds"
    "save-mgba|mGBA saves and states|$root/saves/mgba"
    "save-pcsx2|PCSX2 memory cards and states|$root/saves/pcsx2"
    "save-ppsspp|PPSSPP saves|$HOME/.var/app/org.ppsspp.PPSSPP/config/ppsspp/PSP/SAVEDATA"
    "state-ppsspp|PPSSPP save states|$HOME/.var/app/org.ppsspp.PPSSPP/config/ppsspp/PSP/PPSSPP_STATE"
    "save-retroarch|RetroArch saves|$HOME/.var/app/org.libretro.RetroArch/config/retroarch/saves"
    "state-retroarch|RetroArch save states|$HOME/.var/app/org.libretro.RetroArch/config/retroarch/states"
    "save-rpcs3|RPCS3 saves|$root/storage/rpcs3/dev_hdd0/home/00000001/savedata"
    "trophy-rpcs3|RPCS3 trophies|$root/storage/rpcs3/dev_hdd0/home/00000001/trophy"
    "save-ryujinx|Ryujinx saves|$HOME/.config/Ryujinx/bis/user/save"
    "savemeta-ryujinx|Ryujinx save metadata|$HOME/.config/Ryujinx/bis/user/saveMeta"
    "systemsave-ryujinx|Ryujinx system saves|$HOME/.config/Ryujinx/bis/system/save"
    "save-scummvm|ScummVM saves|$root/saves/scummvm"
    "save-shadps4|shadPS4 saves|$HOME/.local/share/shadPS4/savedata"
    "save-xenia|Xenia saves|$root/roms/xbox360/content"
)

versioning='{"type":"staggered","params":{"maxAge":"31536000"},"cleanupIntervalS":3600,"fsPath":"","fsType":"basic"}'

for entry in "${folders[@]}"; do
    IFS='|' read -r id label path <<<"$entry"
    install -d -m 0750 "$path"
    if "$syncthing" cli config folders list | grep -Fxq "$id"; then
        echo "Already configured: $id"
        continue
    fi
    folder_json="$(jq -nc \
        --arg id "$id" --arg label "$label" --arg path "$path" \
        --arg local_id "$local_id" --arg remote_id "$remote_id" \
        --argjson versioning "$versioning" \
        '{id:$id,label:$label,path:$path,type:"sendonly",devices:[{deviceID:$local_id},{deviceID:$remote_id}],rescanIntervalS:3600,fsWatcherEnabled:true,fsWatcherDelayS:5,ignorePerms:true,minDiskFree:{value:5,unit:"%"},versioning:$versioning}')"
    "$syncthing" cli config folders add-json "$folder_json"
    echo "Added send-only seed folder: $id"
done

echo "Deck save folders are ready to seed Ubuntu."

