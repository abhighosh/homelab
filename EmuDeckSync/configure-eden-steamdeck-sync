#!/usr/bin/env bash
set -Eeuo pipefail

if [[ "$(id -un)" != deck ]]; then
    echo "Run this script as deck, without sudo." >&2
    exit 1
fi
if (( $# != 1 )); then
    echo "Usage: $0 UBUNTU_DEVICE_ID" >&2
    exit 1
fi

remote_id=$1
syncthing="$HOME/.local/bin/syncthing"
local_id="$($syncthing device-id)"

systemctl --user is-active --quiet syncthing.service
if ! "$syncthing" cli config devices list | grep -Fxq "$remote_id"; then
    echo "Ubuntu is not configured as a Syncthing device." >&2
    exit 1
fi

add_folder() {
    local id=$1 label=$2 path=$3 type=$4 versioning_type=$5 versioning_param=$6
    [[ -d "$path" ]] || {
        echo "Missing Deck Eden path: $path" >&2
        exit 1
    }
    if "$syncthing" cli config folders list | grep -Fxq "$id"; then
        "$syncthing" cli config folders "$id" type set "$type"
        "$syncthing" cli config folders "$id" versioning type set "$versioning_type"
        "$syncthing" cli config folders "$id" versioning params set \
            "${versioning_param%%=*}" "${versioning_param#*=}"
        "$syncthing" cli config folders "$id" versioning cleanup-intervals set 3600
        return
    fi
    versioning="$(jq -nc \
        --arg type "$versioning_type" \
        --arg key "${versioning_param%%=*}" \
        --arg value "${versioning_param#*=}" \
        '{type:$type,params:{($key):$value},cleanupIntervalS:3600,fsPath:"",fsType:"basic"}')"
    folder_json="$(jq -nc \
        --arg id "$id" --arg label "$label" --arg path "$path" \
        --arg local_id "$local_id" --arg remote_id "$remote_id" --arg type "$type" \
        --argjson versioning "$versioning" \
        '{id:$id,label:$label,path:$path,type:$type,devices:[{deviceID:$local_id},{deviceID:$remote_id}],rescanIntervalS:3600,fsWatcherEnabled:true,fsWatcherDelayS:5,ignorePerms:true,minDiskFree:{value:5,unit:"%"},versioning:$versioning}')"
    "$syncthing" cli config folders add-json "$folder_json"
}

add_folder eden-keys "Eden Keys" \
    "$HOME/.local/share/eden/keys" receiveonly simple keep=3
add_folder eden-firmware "Eden Firmware" \
    "$HOME/Emulation/storage/eden/nand/system/Contents/registered" receiveonly simple keep=3
add_folder eden-saves "Eden Saves" \
    "$HOME/Emulation/storage/eden/nand/user/save" sendonly staggered maxAge=31536000
add_folder eden-profiles "Eden Profiles" \
    "$HOME/Emulation/storage/eden/nand/system/save/8000000000000010/su/avators" \
    sendonly staggered maxAge=31536000

echo "Deck receives authoritative Eden keys and firmware from Ubuntu."
echo "Saves and profiles remain the protected send-only source during the initial seed."
