#!/bin/sh
set -eu

if [ "$(id -u)" -ne 0 ]; then
    echo "Run this script with sudo." >&2
    exit 1
fi

install -d -m 700 -o gaming -g gaming /home/gaming/.config
install -d -m 700 -o gaming -g gaming /home/gaming/.config/autostart

install -m 600 -o gaming -g gaming /dev/stdin \
    /home/gaming/.config/autostart/steam.desktop <<'EOF'
[Desktop Entry]
Type=Application
Name=Steam
Comment=Start Steam in the background for controller access
Exec=/usr/bin/steam -silent
TryExec=/usr/bin/steam
Terminal=false
OnlyShowIn=GNOME;
X-GNOME-Autostart-enabled=true
EOF

echo "Steam will start automatically for the gaming account at its next login."
echo "The first launch may show setup and sign-in rather than starting silently."

